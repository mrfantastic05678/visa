# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored by default.

# ── Neon PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Sanity CMS ───────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ── Resend (transactional email) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@send.visati.ae
ADMIN_NOTIFICATION_EMAIL=admin@visati.ae

# ── BetterAuth ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# The real admin's email (client's own, non-@visati.ae) — allowlisted alongside
# @visati.ae for signup/forgot-password validation (src/lib/staff-email.ts) and
# used as the sample-data display fallback. Public on purpose (client-side check).
NEXT_PUBLIC_ADMIN_EMAIL=visatillc@gmail.com

# ── App ──────────────────────────────────────────────────────
# Baked into the build at compile time (Docker: passed as a build-arg) — used
# for Stripe checkout redirect URLs, BetterAuth trustedOrigins, email links.
# Changing this after deploy requires a fresh build, not just an env change.
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPRESS_SURCHARGE_AED=99

# ── Cloudflare R2 (document storage) ────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=visati-documents

# ── Stripe ───────────────────────────────────────────────────
# Use a Restricted Key scoped to Checkout Sessions: Write only — the only
# Stripe API call in this codebase is checkout.sessions.create.
STRIPE_SECRET_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
